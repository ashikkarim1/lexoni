# ──────────────────────────────────────────────────────────────────────
# Lexoni.ai - environment template
# Copy to .env.local for local dev. For production, paste each value
# into Vercel Project Settings -> Environment Variables.
# ──────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────
# DATABASE (Neon)
# ──────────────────────────────────────────────────────────────────────
# Use the POOLED connection string from Neon (Settings -> Connection
# string -> "Pooled connection"). The pooled URL ends with "-pooler"
# in the host. Required for Vercel serverless functions; the direct
# connection will exhaust under load.
#
# Format: postgres://USER:PASS@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# ──────────────────────────────────────────────────────────────────────
# ANTHROPIC (AI features)
# ──────────────────────────────────────────────────────────────────────
# Sign up at https://console.anthropic.com -> API keys.
# Without this, Copilot / Memory / Regulatory / Document classifier
# all fall back to deterministic stubs. The wow demos need this.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ──────────────────────────────────────────────────────────────────────
# RESEND (transactional email)
# ──────────────────────────────────────────────────────────────────────
# Sign up at https://resend.com -> API keys. Verify lexoni.ai as a
# sending domain (add SPF + DKIM + DMARC DNS records).
# Without this every send is a silent skip; the audit log still records.
RESEND_API_KEY=
RESEND_FROM=Lexoni.ai <noreply@lexoni.ai>

# ──────────────────────────────────────────────────────────────────────
# PUBLIC URL
# ──────────────────────────────────────────────────────────────────────
# Used to build invite-accept links, password-reset links, invoice
# View links, OG canonicals. Set to the production domain.
NEXT_PUBLIC_APP_URL=https://lexoni.ai

# ──────────────────────────────────────────────────────────────────────
# AUTH SECRETS
# ──────────────────────────────────────────────────────────────────────
# Cookie-signing secret. Generate with: openssl rand -base64 32
# Rotating invalidates every existing session cookie.
AUTH_SECRET=

# Vercel cron auth. Generate with: openssl rand -base64 32
# Vercel sends `Authorization: Bearer <CRON_SECRET>` on scheduled
# invocations of /api/cron/*. Without it, anyone can trigger cron jobs.
CRON_SECRET=

# ──────────────────────────────────────────────────────────────────────
# CLOUDFLARE TURNSTILE (bot protection - optional, recommended)
# ──────────────────────────────────────────────────────────────────────
# Sign up at https://www.cloudflare.com/products/turnstile/. Free.
# When set, every public form (intake, sign-in, signing, accept-invite)
# renders the widget and the server verifies the token.
# When unset, the layered defences (signed honeypot + rate-limit)
# still run; the site is never fully open to anonymous traffic.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ──────────────────────────────────────────────────────────────────────
# DEPLOYMENT MODE OVERRIDE (optional)
# ──────────────────────────────────────────────────────────────────────
# Set to "1" only if you intentionally want the dashboard accessible
# without authentication (e.g. an automated screenshot run). Default
# is locked.
# LEXONI_PUBLIC=
