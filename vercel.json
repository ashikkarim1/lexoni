{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["fra1"],
  "functions": {
    "app/api/auth/**/*": { "maxDuration": 10 },
    "app/api/feedback/**/*": { "maxDuration": 5 },
    "app/api/contact/**/*": { "maxDuration": 5 },
    "app/api/security/challenge/**/*": { "maxDuration": 3 },
    "app/api/memory/**/*": { "maxDuration": 60 },
    "app/api/copilot/**/*": { "maxDuration": 60 },
    "app/api/regulatory/**/*": { "maxDuration": 60 },
    "app/api/cron/**/*": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/reap-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/compliance-reconcile",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/reindex-knowledge",
      "schedule": "0 4 * * 0"
    }
  ]
}
